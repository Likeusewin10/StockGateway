# 同花顺 iFinD 凭据（复制为 .env 并填入真实值；.env 不入库）
THS_USER=your_account
THS_PWD=your_password
# 远程调用鉴权 key（任意随机串，调用方请求头 X-API-Key 需匹配；留空则不鉴权）
API_KEY=change_me_to_a_random_string
# 允许跨域的来源白名单（逗号分隔，如 https://a.com,https://b.com；留空则默认拒绝跨域）
CORS_ORIGINS=
# 注：Wind（WindPy /wind/* 路由）走本机 Wind 终端鉴权，无需账号密码，故此处无 Wind 凭据变量。
# 仅需本机 Wind 金融终端已安装并后台登录（注册与登录见 requirements-wind.txt / CLAUDE.md）。
# 🔴 Wind 交易/写操作总开关：默认关（关时 /wind/call 调 torder/tlogon/wupf 等返回 503）。
# Wind 交易函数签名各异、无固定 order 端点，故走「总开关 + 审计」两层（不做逐笔 dry-run/护栏）。
# 需交易权限的 Wind 终端（通常机构版）+ 显式开启此开关才可下单；开启后经 /wind/call 放行并写审计。
WIND_TRADING_ENABLED=false

# ---- 通达信 TQ（TdxQuant /tdx/* 路由，第四数据源：只读取数 + 独立券商交易腿）----
# 取数走本机通达信终端鉴权，无需账号密码，仅需本机金融终端（64位）已开启并登录，且终端
# 已修复 Python 接口（发现→API插件）。默认指向本机安装路径，换机改这里。
# TDX_PYPLUGINS_DIR=D:\Softwares\new_tdx64\PYPlugins\sys
# 🔴 交易总开关：默认关（关时 /tdx/order、/tdx/cancel 返回 503）。确认风控后再置 true。
# TDX 与 QMT 是两个独立券商腿，配置各自独立、当日下单计数互不干扰。
TDX_TRADING_ENABLED=false
# 资金账号（开启交易前必填）；账号类型默认 STOCK。
TDX_ACCOUNT_ID=your_fund_account
# TDX_ACCOUNT_TYPE=STOCK
# 护栏（下单前硬校验，默认从严）：单笔金额上限(元)、当日笔数上限、标的白名单(逗号分隔,空=不限)。
# TDX_MAX_NOTIONAL=50000
# TDX_DAILY_ORDER_CAP=50
# TDX_CODE_WHITELIST=
# 是否允许非交易时段下单（默认 false；调试可置 true）。
# TDX_ALLOW_OFFHOURS=false

# ---- QMT（君弘君智 / 迅投 XtQuant）交易接口（/qmt/* 路由，券商交易腿之一，与 TDX 平级独立）----
# 🔴 交易总开关：默认关（关时 /qmt/order、/qmt/cancel 返回 503）。确认风控后再置 true。
QMT_TRADING_ENABLED=false
# 资金账号（必填，开启交易前确认无误）；账号类型默认 STOCK（可选 CREDIT/HUGANGTONG/SHENGANGTONG）。
QMT_ACCOUNT_ID=your_fund_account
# QMT_ACCOUNT_TYPE=STOCK
# miniQMT 的 userdata_mini 完整路径（必填）。例：D:\Softwares\君弘君智交易系统\bin.x64\userdata_mini
QMT_USERDATA_PATH=
# 可选：XtQuantTrader 会话号（单 worker 固定即可，默认 100）。
# QMT_SESSION_ID=100
# 可选：xtquant 包目录（默认指向本机君弘君智安装路径，换机时改这里）。
# QMT_PACKAGE_DIR=D:\Softwares\君弘君智交易系统\bin.x64\Lib\site-packages
# 护栏（下单前硬校验，默认从严）：单笔金额上限(元)、当日笔数上限、标的白名单(逗号分隔,空=不限)。
# QMT_MAX_NOTIONAL=50000
# QMT_DAILY_ORDER_CAP=50
# QMT_CODE_WHITELIST=
# 是否允许非交易时段下单（默认 false；调试可置 true）。
# QMT_ALLOW_OFFHOURS=false

# ---- MCP 聚合网关（mcp_gateway，端口 8765，独立于上面的 REST 服务）----
# 网关监听端口；留空默认 8765
MCP_GATEWAY_PORT=8765
# 各厂商上游 MCP 凭据：每个厂商一个变量（绝不下发给远端，仅本机转发用）。
# iFinD：7 个 MCP server 共用的上游 JWT（从 ~/.claude.json 的 Authorization 复制整串）。
IFIND_MCP_JWT=your_ifind_upstream_jwt
# 妙想（东方财富 MX）：单个 MCP server 的上游 API KEY（注入到 em_api_key 请求头）。
# 变量名按官方参考用 MIAO_XIANG_MCP_KEY；上游 connect/read 超时固定为 10/120s。
MIAO_XIANG_MCP_KEY=your_mx_em_api_key
# Tushare：单个 MCP server 的上游 token。🔴 与前两家不同，token 走 URL 查询串（?token=），
# 不是请求头；网关读此变量后拼进上游 URL（凭据不进 header/日志）。工具前缀 tushare_ds_。
TUSHARE_MCP_TOKEN=your_tushare_token
# 以后加新厂商：在 mcp_gateway/providers.py 注册后，在此追加对应凭据变量即可。

# ---- 服务器端 Agent 工具（agent_run/agent_status/agent_result）----
# 鉴权复用上面的 API_KEY（无第二层 key）。🔴 这组工具能让远端无确认在服务器执行任意命令，
# API_KEY 必须强随机且只发可信机器。
# 可选：Agent 子进程执行目录（默认锁死本仓库根，一般不用改）。
# AGENT_PROJECT_DIR=D:\dev\Project\StockSDK

# ---- 多机 Agent 协同（hub + 对等机，见 docs/部署-对等机AgentMCP.md）----
# 网关运行模式：full（默认，hub 形态：厂商上游+agent+peers 全挂载）/
#              agent-only（对等机形态：只暴露本机 agent 工具，供 hub 挂载）。
# MCP_GATEWAY_MODE=full
# hub 侧对等机清单：name=url 逗号分隔；工具前缀 peer_<name>_（如 peer_pc2_agent_run）。
# 🔴 URL 用域名 HTTPS（香港 Caddy 终结 TLS）；frps 明文口被 nftables 封，裸 IP:端口连不通。
# 对等机宕机由 5s connect 超时兜底；长期关机的 peer 建议摘除。
# MCP_PEERS=pc2=https://mcp-pc2.jiantx.net/mcp,mac1=https://mcp-mac1.jiantx.net/mcp
# 每个 peer 一把独立 key（= 该对等机 .env 里的 API_KEY），缺 key 的 peer 跳过不挂载。
# PEER_PC2_API_KEY=
# PEER_PC3_API_KEY=
