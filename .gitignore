# Python 虚拟环境
.venv-em/
.venv-ths/
.venv*/
__pycache__/
*.py[cod]

# 凭据与登录令牌 —— 绝不入库
.env
userInfo
docs/quantapi/相关信息.txt

# SSH 密钥（连香港 frps 节点用）—— 私钥绝不入库
.ssh-frp/

# frp 认证 token —— 绝不入库（start_frpc.bat 启动前 call 设为环境变量）
frpc.secret.bat
# macOS 对等机的 frp token（launchd 经 sh -c source 后起 frpc）—— 同样绝不入库
frpc.secret.sh
# frpc 计划任务定义 —— register_frpc_task.ps1 自动生成的派生物
frpc_task_def.xml
# 对等机(peer)专属派生物：frpc_peer.toml 从 example 复制填端口后各机不同,不入库
frpc_peer.toml
frpc_peer_task_def.xml
# MCP 网关计划任务定义 —— register_mcp_gateway_task.ps1 自动生成
mcp_gateway_task_def.xml
# frpc.exe 二进制（大文件，各机自行下载，不入库）
frp/frpc.exe
frp/*.zip

# 日志
*.log

# 计划任务定义 —— 由 register_task.ps1 自动生成的派生产物
task_def.xml
# 同上，由 register_ngrok_task.ps1 自动生成
ngrok_task_def.xml

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Claude Code 本机配置 / 记忆 / 计划（个人本机态，不入库）
.claude/

# 桌面客户端安装包（大文件，不入库）
downloads/
THSDataInterface_Windows_*.zip
THSDataInterface/

# 测试覆盖率产物
.coverage

# Obsidian 本机 UI 配置（只同步 ops/board/ 的 .md，不同步工作区状态）
.obsidian/

# QMT 交易审计日志（本机留痕，不入库）
audit/

# 小盘股抓取的原始中间产物（派生数据，不入库）
smallcap_scrape/_raw/

# iFinD 命令生成器原始抓取(70MB,只提交归一化后的 CSV+手册)
docs/catalog/_raw/

# 通达信 TdxQuant 接口文档原始件(30MB PDF + 抽出的全文,只作本机参考,不入库)
docs/catalog/tdx/_raw/

# 调试探针临时输出
tdx_probe_*.txt
